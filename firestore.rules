rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
            && data.email is string && data.email.matches('^.+@.+$')
            && data.skillsOffered is list && data.skillsOffered.size() <= 20
            && (data.skillsOffered.size() == 0 || (data.skillsOffered[0] is map && data.skillsOffered[0].name is string && data.skillsOffered[0].category is string && (!('description' in data.skillsOffered[0]) || data.skillsOffered[0].description is string)))
            && data.skillsWanted is list && data.skillsWanted.size() <= 20
            && (data.skillsWanted.size() == 0 || (data.skillsWanted[0] is map && data.skillsWanted[0].name is string && data.skillsWanted[0].category is string && (!('description' in data.skillsWanted[0]) || data.skillsWanted[0].description is string)))
            && data.subscriptionPlan in ['free', 'pro']
            && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 600))
            && (!('username' in data) || (data.username is string && data.username.size() >= 3 && data.username.size() <= 30 && data.username.matches('^[a-zA-Z0-9_]+$')))
            && (!('portfolioUrl' in data) || (data.portfolioUrl is string && data.portfolioUrl.size() <= 300))
            && (!('country' in data) || (data.country is string && data.country.size() <= 100))
            && (!('autoTranslate' in data) || data.autoTranslate is bool)
            && (!('testimonials' in data) || (data.testimonials is list && data.testimonials.size() <= 10));
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Basic marketplace discovery
      
      allow create: if isOwner(userId) 
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time;
      
      allow update: if isOwner(userId)
                    && isValidUser(incoming())
                    && incoming().createdAt == existing().createdAt;
    }

    // --- Trade Rules ---
    match /trades/{tradeId} {
      function isValidTrade(data) {
        return data.senderId is string && data.receiverId is string
            && data.skillOffered is string && data.skillOffered.size() <= 200
            && data.skillWanted is string && data.skillWanted.size() <= 200
            && data.status in ['pending', 'accepted', 'declined', 'completed']
            && (!('senderReview' in data) || (data.senderReview is map && data.senderReview.rating is number && data.senderReview.comment is string))
            && (!('receiverReview' in data) || (data.receiverReview is map && data.receiverReview.rating is number && data.receiverReview.comment is string));
      }

      allow get: if isSignedIn() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);

      allow create: if isSignedIn() 
                    && incoming().senderId == request.auth.uid
                    && isValidTrade(incoming())
                    && incoming().status == 'pending'
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;

      allow update: if isSignedIn() 
                    && (request.auth.uid == existing().senderId || request.auth.uid == existing().receiverId)
                    && isValidTrade(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().updatedAt == request.time
                    && (
                      // Action: Receiver responds
                      (request.auth.uid == existing().receiverId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                      // Action: Either marks as completed
                      (incoming().status == 'completed' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                      // Action: Sender reviews
                      (request.auth.uid == existing().senderId && incoming().diff(existing()).affectedKeys().hasOnly(['senderReview', 'updatedAt'])) ||
                      // Action: Receiver reviews
                      (request.auth.uid == existing().receiverId && incoming().diff(existing()).affectedKeys().hasOnly(['receiverReview', 'updatedAt']))
                    );
    }

    // --- Notifications ---
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId);
    }

    // --- Post Rules ---
    match /posts/{postId} {
      function isValidPost(data) {
        return data.userId is string && data.userId == request.auth.uid
            && data.userName is string && data.userName.size() > 0
            && data.content is string && data.content.size() > 0 && data.content.size() <= 2000
            && (!('likes' in data) || (data.likes is list && data.likes.size() <= 1000));
      }

      allow read: if isSignedIn();
      
      allow create: if isSignedIn()
                    && isValidPost(incoming())
                    && incoming().createdAt == request.time;
                    
      allow update: if isSignedIn()
                    && (
                      // Only allow liking/unliking or owner edit
                      (isOwner(existing().userId) && isValidPost(incoming())) ||
                      (incoming().diff(existing()).affectedKeys().hasOnly(['likes']))
                    );
      
      allow delete: if isOwner(existing().userId);
    }
  }
}
